<div class="terminal" role="group" aria-label="Pixir terminal transcript">
  <div class="terminal-head">
    <span class="window-dots" aria-hidden="true"><span></span><span></span><span></span></span>
    <span>pixir · local runtime</span>
  </div>
  <div class="terminal-body">
    <div><span class="prompt">$</span> mix escript.install hex pixir</div>
    <div class="dim">Resolving Hex dependencies...</div>
    <div class="ok">Generated escript pixir with MIX_ENV=prod</div>
    <br />
    <div><span class="prompt">$</span> pixir doctor --json</div>
    <div class="json">{"{"}"ok":true,"status":"ready","version":"0.1.8"{"}"}</div>
    <br />
    <div><span class="prompt">$</span> pixir tree &lt;session-id&gt; --json</div>
    <div class="json">{"{"}"session":"...","children":[],"log":"append-only"{"}"}</div>
  </div>
</div>
