  "kitVersion": "0.3.4-alpha.1",
  "packageScripts": {
    "patch:accept": "uv run scripts/patch_cli.py accept",
    "patch:artifacts:prune": "uv run scripts/patch_cli.py artifacts-prune",
    "patch:classify": "uv run scripts/patch_cli.py classify",
    "patch:diff:snapshot": "uv run scripts/patch_cli.py diff-snapshot",
    "patch:drift:analyze": "uv run scripts/patch_cli.py drift-analyze",
    "patch:proof:playwright": "uv run scripts/patch_cli.py proof-playwright",
    "patch:proof:runtime": "uv run scripts/patch_cli.py proof-runtime",
    "patch:review:coderabbit": "uv run scripts/patch_cli.py review-coderabbit",
    "patch:status": "uv run scripts/patch_cli.py status",
    "patch:truth:check": "uv run scripts/patch_cli.py truth-check",
    "patch:worktree:init": "uv run scripts/patch_cli.py worktree-init"
  },
  "playwrightProofCommands": [],
  "profile": "review-proof",
  "repoLawFile": "AGENTS.md",
  "repo_law": "AGENTS.md",
  "reviewProvider": "coderabbit",
  "runtimeProofCommands": [],
  "schemaVersion": 1,
  "schemaVersions": {
    "classification": 1,
    "patchSpec": 1
