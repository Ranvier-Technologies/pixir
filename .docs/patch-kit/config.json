{
  "adapter": {
    "ci_provider": null,
    "package_manager": "unknown",
    "task_runner": "uv",
    "test_command": null
  },
  "artifactRoot": ".docs/patches",
  "branches": {
    "default_target": null,
    "donor_remote": null
  },
  "capabilities": {
    "patch:accept": true,
    "patch:artifacts:prune": true,
    "patch:classify": true,
    "patch:diff:snapshot": true,
    "patch:drift:analyze": true,
    "patch:proof:playwright": true,
    "patch:proof:runtime": true,
    "patch:review:coderabbit": true,
    "patch:status": true,
    "patch:truth:check": true,
    "patch:worktree:init": true
  },
  "capabilityNames": [
    "patch:accept",
    "patch:artifacts:prune",
    "patch:classify",
    "patch:diff:snapshot",
    "patch:drift:analyze",
    "patch:proof:playwright",
    "patch:proof:runtime",
    "patch:review:coderabbit",
    "patch:status",
    "patch:truth:check",
    "patch:worktree:init"
  ],
  "commandRunner": "unknown",
  "defaultAcceptanceCommands": [],
  "defaults": {
    "artifact_root": ".docs/patches",
