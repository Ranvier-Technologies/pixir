{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pixir.dev/schemas/pixir.presenter.run.v1.schema.json",
  "title": "Pixir Presenter Run Projection v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "schema_version",
    "projection_id",
    "projected_at",
    "run",
    "source",
    "execution",
    "liveness",
    "counts",
    "graph",
    "units",
    "usage",
    "mutation",
    "safe_actions",
    "evidence",
    "limitations"
  ],
  "properties": {
    "schema": {"const": "pixir.presenter.run"},
    "schema_version": {"const": 1},
    "projection_id": {"type": "string", "minLength": 1},
    "projected_at": {"type": "string", "format": "date-time"},
    "run": {"$ref": "#/$defs/run"},
    "source": {"$ref": "#/$defs/source"},
    "execution": {"$ref": "#/$defs/execution"},
    "liveness": {"$ref": "#/$defs/liveness"},
    "counts": {"$ref": "#/$defs/counts"},
    "graph": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/graph"}
      ]
    },
    "units": {
      "type": "array",
      "items": {"$ref": "#/$defs/unit"}
    },
    "usage": {"$ref": "#/$defs/usage"},
    "mutation": {"$ref": "#/$defs/mutation"},
    "safe_actions": {
      "type": "array",
      "items": {"$ref": "#/$defs/safeAction"}
    },
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidence"}
    },
    "limitations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  },
  "$defs": {
    "nullableString": {
      "type": ["string", "null"]
    },
    "nullableDateTime": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "stringList": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "delegate_id",
        "parent_session_id",
        "workflow_id",
        "strategy",
        "mode",
        "title",
        "evidence_refs"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "delegate_id": {"$ref": "#/$defs/nullableString"},
        "parent_session_id": {"$ref": "#/$defs/nullableString"},
        "workflow_id": {"$ref": "#/$defs/nullableString"},
        "strategy": {"enum": ["workflow", "subagents", "unknown"]},
        "mode": {"enum": ["read_only", "bounded_write", "unknown"]},
        "title": {"$ref": "#/$defs/nullableString"},
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "durable_origin",
        "as_of_seq",
        "last_durable_at",
        "live_observed_at",
        "freshness",
        "limitations"
      ],
      "properties": {
        "mode": {"enum": ["live", "reconstructed", "mixed"]},
        "durable_origin": {
          "enum": ["workspace_log", "evidence_mirror", "fixture", "none"]
        },
        "as_of_seq": {"type": ["integer", "null"], "minimum": 0},
        "last_durable_at": {"$ref": "#/$defs/nullableDateTime"},
        "live_observed_at": {"$ref": "#/$defs/nullableDateTime"},
        "freshness": {"enum": ["current", "stale", "terminal", "unknown"]},
        "limitations": {"$ref": "#/$defs/stringList"}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "terminal", "basis", "evidence_refs"],
      "properties": {
        "state": {
          "enum": [
            "planned",
            "queued",
            "running",
            "completed",
            "partial",
            "failed",
            "timed_out",
            "cancelled",
            "detached",
            "closed",
            "held",
            "unknown"
          ]
        },
        "terminal": {"type": "boolean"},
        "basis": {
          "enum": [
            "parent_log",
            "workflow_event_fold",
            "subagent_event_fold",
            "terminal_envelope",
            "deterministic_fold",
            "unknown"
          ]
        },
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      }
    },
    "liveness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reachable", "basis", "observed_at", "evidence_refs"],
      "properties": {
        "state": {
          "enum": [
            "live",
            "stale_handle",
            "owner_unavailable",
            "not_applicable",
            "unknown"
          ]
        },
        "reachable": {"type": ["boolean", "null"]},
        "basis": {
          "enum": [
            "manager_diagnostics",
            "delegate_owner",
            "durable_snapshot",
            "terminal_execution",
            "none"
          ]
        },
        "observed_at": {"$ref": "#/$defs/nullableDateTime"},
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "planned_units",
        "observed_units",
        "running_units",
        "completed_units",
        "attention_units"
      ],
      "properties": {
        "planned_units": {"type": ["integer", "null"], "minimum": 0},
        "observed_units": {"type": "integer", "minimum": 0},
        "running_units": {"type": "integer", "minimum": 0},
        "completed_units": {"type": "integer", "minimum": 0},
        "attention_units": {"type": "integer", "minimum": 0}
      }
    },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["waves", "edges"],
      "properties": {
        "waves": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to", "state"],
            "properties": {
              "from": {"type": "string"},
              "to": {"type": "string"},
              "state": {"enum": ["ready", "blocked", "unknown"]}
            }
          }
        }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "dependent_safe", "basis", "evidence_refs"],
      "properties": {
        "state": {
          "enum": [
            "checkpoint_ready",
            "partial",
            "failed",
            "held",
            "needs_orchestrator",
            "not_applicable",
            "unknown"
          ]
        },
        "dependent_safe": {"type": ["boolean", "null"]},
        "basis": {
          "enum": ["workflow_event", "terminal_envelope", "not_applicable", "unknown"]
        },
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      }
    },
    "advisory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "present",
        "verdict",
        "mergeable",
        "declared_gate",
        "parse_status",
        "summary",
        "major_count",
        "minor_count",
        "evidence_refs"
      ],
      "properties": {
        "present": {"type": "boolean"},
        "verdict": {"enum": ["pass", "stop", "needs_review", "unknown"]},
        "mergeable": {"type": ["boolean", "null"]},
        "declared_gate": {"$ref": "#/$defs/nullableString"},
        "parse_status": {"enum": ["valid", "invalid", "not_present"]},
        "summary": {"$ref": "#/$defs/nullableString"},
        "raw_excerpt": {"type": "string", "maxLength": 4096},
        "major_count": {"type": ["integer", "null"], "minimum": 0},
        "minor_count": {"type": ["integer", "null"], "minimum": 0},
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attempt_id",
        "ordinal",
        "materialization",
        "status_basis",
        "relation",
        "predecessor_attempt_id",
        "child_session_id",
        "status",
        "started_at",
        "ended_at",
        "error_kind",
        "summary",
        "child_event_window",
        "evidence_refs",
        "limitations"
      ],
      "properties": {
        "attempt_id": {"type": "string", "minLength": 1},
        "ordinal": {"type": ["integer", "null"], "minimum": 0},
        "materialization": {"enum": ["durable", "volatile_only"]},
        "status_basis": {"enum": ["parent_log", "volatile_runtime"]},
        "relation": {"enum": ["fresh", "retry", "resume", "unknown"]},
        "predecessor_attempt_id": {"$ref": "#/$defs/nullableString"},
        "child_session_id": {"$ref": "#/$defs/nullableString"},
        "status": {
          "enum": [
            "queued",
            "running",
            "completed",
            "failed",
            "timed_out",
            "cancelled",
            "detached",
            "closed",
            "unknown"
          ]
        },
        "started_at": {"$ref": "#/$defs/nullableDateTime"},
        "ended_at": {"$ref": "#/$defs/nullableDateTime"},
        "error_kind": {"$ref": "#/$defs/nullableString"},
        "summary": {"$ref": "#/$defs/nullableString"},
        "child_event_window": {"$ref": "#/$defs/childEventWindow"},
        "usage": {"$ref": "#/$defs/usage"},
        "evidence_refs": {"$ref": "#/$defs/stringList"},
        "limitations": {"$ref": "#/$defs/stringList"}
      }
    },
    "childEventWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "from_seq",
        "to_seq_exclusive",
        "basis",
        "evidence_refs"
      ],
      "properties": {
        "session_id": {"$ref": "#/$defs/nullableString"},
        "from_seq": {"type": ["integer", "null"], "minimum": 0},
        "to_seq_exclusive": {"type": ["integer", "null"], "minimum": 0},
        "basis": {
          "enum": [
            "whole_child_log_single_attempt",
            "child_user_message_epoch",
            "explicit_attempt_marker",
            "unknown"
          ]
        },
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "version",
        "hash",
        "status",
        "workspace_strategy",
        "producer_unit_id",
        "source_artifact_hash",
        "application_state",
        "applied_by_unit_id",
        "correlation",
        "evidence_refs"
      ],
      "properties": {
        "kind": {"type": "string", "minLength": 1},
        "version": {"type": ["integer", "null"], "minimum": 1},
        "hash": {"$ref": "#/$defs/nullableString"},
        "status": {"enum": ["produced", "not_applied", "applied", "failed", "unknown"]},
        "workspace_strategy": {"$ref": "#/$defs/nullableString"},
        "producer_unit_id": {"$ref": "#/$defs/nullableString"},
        "source_artifact_hash": {"$ref": "#/$defs/nullableString"},
        "application_state": {
          "enum": ["not_applied", "applied", "failed", "conflicted", "not_applicable", "unknown"]
        },
        "applied_by_unit_id": {"$ref": "#/$defs/nullableString"},
        "correlation": {"enum": ["matched", "missing", "mismatch", "not_applicable", "unknown"]},
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      }
    },
    "usageGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model",
        "calls",
        "input_tokens",
        "output_tokens",
        "reasoning_tokens",
        "total_tokens",
        "cached_tokens",
        "cache_creation_tokens",
        "cache_read_tokens"
      ],
      "properties": {
        "provider": {"type": "string", "minLength": 1},
        "model": {"type": "string", "minLength": 1},
        "calls": {"type": "integer", "minimum": 1},
        "input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "reasoning_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "cached_tokens": {"type": "integer", "minimum": 0},
        "cache_creation_tokens": {"type": "integer", "minimum": 0},
        "cache_read_tokens": {"type": "integer", "minimum": 0}
      }
    },
    "usage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "complete", "calls", "groups", "evidence_refs", "limitations"],
      "properties": {
        "source": {"enum": ["provider_usage_fold", "none", "incomplete"]},
        "complete": {"type": "boolean"},
        "calls": {"type": "integer", "minimum": 0},
        "groups": {
          "type": "array",
          "items": {"$ref": "#/$defs/usageGroup"}
        },
        "evidence_refs": {"$ref": "#/$defs/stringList"},
        "limitations": {"$ref": "#/$defs/stringList"}
      }
    },
    "mutation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "observed_paths", "observed_semantics", "evidence_refs", "limitations"],
      "properties": {
        "status": {
          "enum": [
            "read_only",
            "none",
            "workspace_applied",
            "isolated_only",
            "partial",
            "indeterminate",
            "not_applied",
            "unknown"
          ]
        },
        "observed_paths": {"$ref": "#/$defs/stringList"},
        "observed_semantics": {"enum": ["exact", "at_least", "none", "unknown"]},
        "evidence_refs": {"$ref": "#/$defs/stringList"},
        "limitations": {"$ref": "#/$defs/stringList"}
      }
    },
    "safeAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "scope",
        "kind",
        "effect",
        "presentation",
        "command",
        "source_field",
        "evidence_refs"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "scope": {"type": "string", "minLength": 1},
        "kind": {"enum": ["inspect", "diagnose", "resume", "retry", "cancel", "apply", "other"]},
        "effect": {"enum": ["read_only", "mutating"]},
        "presentation": {"enum": ["informational", "copy_only"]},
        "command": {"$ref": "#/$defs/nullableString"},
        "source_field": {
          "enum": [
            "safe_next_actions",
            "next_actions",
            "diagnose_command",
            "resume_command",
            "virtual_diff_apply_hint"
          ]
        },
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      },
      "allOf": [
        {
          "if": {"properties": {"presentation": {"const": "copy_only"}}},
          "then": {"properties": {"command": {"type": "string", "minLength": 1}}}
        }
      ]
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "authority", "source_kind", "session_id", "seq", "description"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "authority": {"enum": ["canonical", "derived", "volatile", "model_declared", "artifact"]},
        "source_kind": {
          "enum": [
            "parent_log",
            "child_log",
            "evidence_mirror",
            "delegate_snapshot",
            "terminal_envelope",
            "diagnose",
            "tree",
            "manager_diagnostics",
            "delegate_owner",
            "model_summary",
            "artifact",
            "fixture"
          ]
        },
        "session_id": {"$ref": "#/$defs/nullableString"},
        "seq": {"type": ["integer", "null"], "minimum": 0},
        "description": {"type": "string", "minLength": 1}
      }
    },
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logical_id",
        "unit_kind",
        "materialization",
        "label",
        "agent",
        "execution_kind",
        "workspace_mode",
        "posture",
        "depends_on",
        "execution",
        "liveness",
        "gate",
        "advisory",
        "attempts",
        "artifacts",
        "usage",
        "mutation",
        "attention",
        "safe_actions",
        "evidence_refs",
        "limitations"
      ],
      "properties": {
        "logical_id": {"type": "string", "minLength": 1},
        "unit_kind": {"enum": ["workflow_step", "subagent"]},
        "materialization": {"enum": ["durable", "volatile_only"]},
        "label": {"type": "string", "minLength": 1},
        "agent": {"$ref": "#/$defs/nullableString"},
        "execution_kind": {"enum": ["subagent", "virtual_overlay", "virtual_diff_apply", "unknown"]},
        "workspace_mode": {"enum": ["shared", "isolated", "virtual_overlay", "unknown"]},
        "posture": {"enum": ["read_only", "writer", "virtual_scratch", "apply", "unknown"]},
        "depends_on": {"$ref": "#/$defs/stringList"},
        "execution": {"$ref": "#/$defs/execution"},
        "liveness": {"$ref": "#/$defs/liveness"},
        "gate": {"$ref": "#/$defs/gate"},
        "advisory": {"$ref": "#/$defs/advisory"},
        "attempts": {
          "type": "array",
          "items": {"$ref": "#/$defs/attempt"}
        },
        "artifacts": {
          "type": "array",
          "items": {"$ref": "#/$defs/artifact"}
        },
        "usage": {"$ref": "#/$defs/usage"},
        "mutation": {"$ref": "#/$defs/mutation"},
        "attention": {"$ref": "#/$defs/attention"},
        "safe_actions": {
          "type": "array",
          "items": {"$ref": "#/$defs/safeAction"}
        },
        "evidence_refs": {"$ref": "#/$defs/stringList"},
        "limitations": {"$ref": "#/$defs/stringList"}
      }
    },
    "attention": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "reasons", "evidence_refs"],
      "properties": {
        "required": {"type": "boolean"},
        "reasons": {
          "type": "array",
          "items": {
            "enum": [
              "execution_failed",
              "execution_timed_out",
              "execution_cancelled",
              "execution_detached",
              "execution_partial",
              "execution_held",
              "execution_unknown",
              "gate_partial",
              "gate_failed",
              "gate_held",
              "gate_needs_orchestrator",
              "gate_unknown",
              "advisory_stop",
              "advisory_needs_review",
              "advisory_gate_disagreement",
              "advisory_unparseable",
              "nonterminal_stale_handle",
              "nonterminal_owner_unavailable",
              "nonterminal_liveness_unknown",
              "terminal_ambiguous_close",
              "mutation_partial",
              "mutation_indeterminate",
              "mutation_unknown",
              "virtual_diff_unapplied",
              "virtual_diff_apply_failed",
              "virtual_diff_correlation_unknown",
              "canonical_source_conflict",
              "durable_log_unavailable",
              "child_log_missing",
              "attempt_index_conflict"
            ]
          },
          "uniqueItems": true
        },
        "evidence_refs": {"$ref": "#/$defs/stringList"}
      }
    }
  }
}
